) raises:
    """Full any() over a bool tensor -> scalar bool (OR). Single-block for the
    common small case, stdlib library for the rare huge case (`_bool_full_reduce`).
    """
    _bool_full_reduce[is_all=False](out_addr, in_addr, size, ctx)


def _any_bool_go(
